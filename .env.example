# Server-only (never VITE_*) — loaded by server/index.js via dotenv locally.
# On Render: add these in Dashboard → Environment.

# Only this is required — we default to ElevenLabs preset “Rachel” unless you set ELEVENLABS_VOICE_ID.
ELEVENLABS_API_KEY=

# Optional — any voice from https://elevenlabs.io/app/voice-library (ID in URL / voice settings)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional — if TTS errors, try: eleven_multilingual_v2
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Optional: only if frontend is hosted separately from the API (unusual for this app).
# VITE_SERVER_URL=https://your-api.onrender.com
